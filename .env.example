# OpenAI API 키
# https://platform.openai.com/api-keys 에서 발급
OPENAI_API_KEY=

# Supabase 프로젝트 URL
# Supabase 대시보드 → Settings → API → Project URL
SUPABASE_URL=

# Supabase anon public 키
# Supabase 대시보드 → Settings → API → anon public
SUPABASE_ANON_KEY=

# 기존 AI 서버 URL (기본값: http://ai:8001/predict)
AI_URL=http://ai:8001/predict